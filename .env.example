# ─── Parselfee Environment Variables ───
# Copy this file to .env and fill in the values.

# REQUIRED — JWT signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Server port (default: 3000)
PORT=3000

# Set to 'production' for secure cookies & strict CORS
NODE_ENV=development

# CORS — allowed origin in production (e.g. https://parselfee.example.com)
# ALLOWED_ORIGIN=
